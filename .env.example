# .env.example — Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env

# ─── Base de Datos ──────────────────────────────
DB_PASSWORD=cambia_esta_password_en_produccion

# ─── Supabase ────────────────────────────────────
# Obtener desde: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL JWKS para validar JWTs en Spring Security
# Formato: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URI=https://TU_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# ─── CORS (producción) ───────────────────────────
APP_CORS_WEB_ORIGIN=https://web.tudominio.com
APP_CORS_ALLOWED_ORIGINS=https://api.tudominio.com

# ─── Dominios (producción) ───────────────────────
# Usados para referencia en Cloudflared y documentación
WEB_DOMAIN=web.tudominio.com
API_DOMAIN=api.tudominio.com
